{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/pre-merge-check.js",
            "timeout": 10,
            "statusMessage": "Kiểm tra code review trước khi merge..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/update-roadmap.js",
            "timeout": 30,
            "statusMessage": "Cập nhật ROADMAP.md...",
            "async": true
          }
        ]
      }
    ]
  }
}
